AI_PROVIDER=openai-compatible
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=replace-with-your-api-key
AI_MODEL=replace-with-your-model-name
AI_TIMEOUT_SECONDS=60
# Optional: bypass a local VPN/system proxy for this API host.
NO_PROXY=api.example.com

# Local NLTK + Hugging Face/BERT provider. Set false once the model has been
# downloaded or when the runtime is allowed to download it from Hugging Face.
LOCAL_BERT_MODEL=uer/chinese_roberta_L-2_H-128
LOCAL_MODEL_FILES_ONLY=false
LOCAL_MODEL_WARMUP=true
LOCAL_SCORING_MODEL=./models/aes-scorer
LOCAL_GRAMMAR_MODEL=./models/grammar-detector
